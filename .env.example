# ---- Database ----
DATABASE_URL=postgresql+psycopg://nksquared_user:dev@postgres:5432/nksquared

# ---- Cache / queue broker ----
REDIS_URL=redis://redis:6379/0

# ---- Auth / signing ----
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MIN=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# ---- URLs ----
FRONTEND_URL=http://localhost:5173

# ---- Frontend (Vite) ----
# Browser-side code can only read VITE_* vars. Used by the dev server proxy.
VITE_API_URL=http://localhost:8000
