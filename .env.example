# ---- Database ----
DATABASE_URL=postgresql+psycopg://nksquared_user:dev@postgres:5432/nksquared

# ---- Cache / queue broker ----
REDIS_URL=redis://redis:6379/0

# ---- Auth / signing ----
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MIN=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# ---- URLs ----
FRONTEND_URL=http://localhost:5173

# ---- Frontend (Vite) ----
# Browser-side code can only read VITE_* vars. Used by the dev server proxy.
VITE_API_URL=http://localhost:8000
VITE_CHATBOT_URL=http://localhost:8001

# ---- Email (SMTP — defaults target the local MailHog container) ----
# In prod, point at your relay (SendGrid SMTP, SES, etc.) and set credentials.
SMTP_HOST=mailhog
SMTP_PORT=1025
# SMTP_USERNAME=
# SMTP_PASSWORD=
SMTP_USE_TLS=false
EMAIL_FROM=noreply@nksquared.local
EMAIL_FROM_NAME=NKSquared
FUND_NAME=NKSquared
# Used to build the upload links in reminder emails.
PUBLIC_UPLOAD_BASE_URL=http://localhost:5173
REMINDER_TOKEN_TTL_DAYS=30

# ---- Chatbot (Azure OpenAI) ----
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ---- Voice / Vapi ----
VAPI_PUBLIC_KEY=your-vapi-public-key
VAPI_SHARED_SECRET=your-vapi-shared-secret
VAPI_ASSISTANT_ID=your-vapi-assistant-id
VOICE_COMPRESSOR_DEPLOYMENT=gpt-4o-mini
VOICE_COMPRESSOR_API_VERSION=2024-08-01-preview
VAPI_SERVER_AUTH_DISABLED=false

# Live FX rate fetcher. Provider is one of: currencylayer | fixer.
# Free tiers lock the request base: currencylayer→USD, fixer→EUR.
# Triangulation to INR happens regardless of base.
FX_PROVIDER=currencylayer
FX_API_KEY=
FX_BASE_CURRENCY=USD
FX_REFRESH_HOURS=2